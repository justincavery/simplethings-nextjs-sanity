---
import type { MediaValue } from "emdash";
import { Image } from "emdash/ui";
import {
	asPositiveInteger,
	defaultHomeSections,
	normaliseHomeSections,
	parseSectionItems,
	type HomeSection,
} from "../lib/home-sections";

type EntryLike = {
	id: string;
	data: Record<string, any>;
};

export interface Props {
	sections?: unknown;
	projects?: EntryLike[];
	posts?: EntryLike[];
	showFieldDesign?: boolean;
	edit?: Record<string, any>;
}

const {
	sections,
	projects = [],
	posts = [],
	showFieldDesign = false,
	edit,
} = Astro.props;

const editableSections = normaliseHomeSections(sections);
const renderedSections = editableSections.length ? editableSections : defaultHomeSections;
const asMedia = (value: unknown) => value as MediaValue | string | null | undefined;

function limited<T>(items: T[], section: HomeSection, fallback = 4): T[] {
	return items.slice(0, asPositiveInteger(section.limit, fallback));
}

function sectionItems(section: HomeSection) {
	return parseSectionItems(section.items);
}

function actionPair(section: HomeSection) {
	return [
		{ label: section.primary_label, url: section.primary_url, primary: true },
		{ label: section.secondary_label, url: section.secondary_url, primary: false },
	].filter((action) => action.label && action.url);
}
---

<div class="home-sections" {...edit?.sections}>
	{renderedSections.map((section) => (
		<>
			{section.type === "hero" && (
				<section class:list={["hero", { "hero-field": section.variant === "field" }]}>
					<div class="hero-copy">
						{section.eyebrow && <p class="eyebrow">{section.eyebrow}</p>}
						{section.title && <h1>{section.title}</h1>}
						{section.summary && <p class="lede">{section.summary}</p>}
						{actionPair(section).length > 0 && (
							<div class="hero-actions">
								{actionPair(section).map((action) => (
									<a href={action.url} class:list={["button", { primary: action.primary }]}>
										{action.label}
									</a>
								))}
							</div>
						)}
					</div>
					{showFieldDesign && sectionItems(section).length > 0 && (
						<aside class="field-notes" aria-label="Working notes">
							<p class="note-kicker">Current desk</p>
							<h2>Systems made boring enough to trust.</h2>
							<dl>
								{sectionItems(section).map((item) => (
									<div>
										<dt>{item.title}</dt>
										{item.summary && <dd>{item.summary}</dd>}
									</div>
								))}
							</dl>
						</aside>
					)}
				</section>
			)}

			{section.type === "steps" && (
				<section class="home-steps" aria-label={section.title || "Simple steps"}>
					{section.title && (
						<div class="section-head compact">
							<div>
								{section.eyebrow && <p class="eyebrow">{section.eyebrow}</p>}
								<h2>{section.title}</h2>
							</div>
						</div>
					)}
					<div class="steps-grid">
						{sectionItems(section).map((item, index) => (
							<div>
								<span>{String(index + 1).padStart(2, "0")}</span>
								<strong>{item.title}</strong>
								{item.summary && <p>{item.summary}</p>}
							</div>
						))}
					</div>
				</section>
			)}

			{section.type === "services" && (
				<section class="band">
					<div class="section-head">
						<h2>{section.title || "Services"}</h2>
						{section.primary_label && section.primary_url && <a href={section.primary_url}>{section.primary_label}</a>}
					</div>
					<div class="service-grid">
						{sectionItems(section).map((item) => (
							<article class="service-item">
								<h3>{item.title}</h3>
								{item.summary && <p>{item.summary}</p>}
							</article>
						))}
					</div>
				</section>
			)}

			{section.type === "projects" && (
				<section class="band">
					<div class="section-head">
						<h2>{section.title || "Projects"}</h2>
						{section.primary_label && section.primary_url && <a href={section.primary_url}>{section.primary_label}</a>}
					</div>
					<div class="cards">
						{limited(projects, section).map((project) => (
							<article class="card">
								<a href={`/projects/${project.id}`}>
									{!showFieldDesign && asMedia(project.data.featured_image) && (
										<Image image={asMedia(project.data.featured_image)} />
									)}
									<span>{project.data.year}</span>
									<h3>{project.data.title}</h3>
									<p>{project.data.summary}</p>
								</a>
							</article>
						))}
					</div>
				</section>
			)}

			{section.type === "posts" && (
				<section class="band">
					<div class="section-head">
						<h2>{section.title || "Recent writing"}</h2>
						{section.primary_label && section.primary_url && <a href={section.primary_url}>{section.primary_label}</a>}
					</div>
					<div class="post-list">
						{limited(posts, section).map((post) => (
							<a href={`/posts/${post.id}`} class="post-row">
								<span>{post.data.date}</span>
								<strong>{post.data.title}</strong>
								<p>{post.data.excerpt}</p>
							</a>
						))}
					</div>
				</section>
			)}

			{section.type === "rich_text" && (
				<section class="band text-band">
					{section.eyebrow && <p class="eyebrow">{section.eyebrow}</p>}
					{section.title && <h2>{section.title}</h2>}
					{section.summary && <p class="lede">{section.summary}</p>}
					{section.body && section.body.split(/\r?\n\r?\n/).map((paragraph) => <p>{paragraph}</p>)}
				</section>
			)}

			{section.type === "cta" && (
				<section class="home-cta">
					{section.eyebrow && <p class="eyebrow">{section.eyebrow}</p>}
					{section.title && <h2>{section.title}</h2>}
					{section.summary && <p>{section.summary}</p>}
					{actionPair(section).length > 0 && (
						<div class="hero-actions">
							{actionPair(section).map((action) => (
								<a href={action.url} class:list={["button", { primary: action.primary }]}>
									{action.label}
								</a>
							))}
						</div>
					)}
				</section>
			)}
		</>
	))}
</div>

<style>
	.hero,
	.band,
	.home-steps,
	.home-cta {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-4xl) var(--spacing-lg);
	}

	.hero {
		padding-top: clamp(4rem, 10vw, 8rem);
		padding-bottom: clamp(4rem, 9vw, 7rem);
	}

	.eyebrow {
		color: var(--color-accent);
		font-size: var(--font-size-sm);
		font-weight: 700;
		margin-bottom: var(--spacing-lg);
		text-transform: uppercase;
	}

	h1 {
		max-width: 920px;
		font-size: clamp(2.6rem, 8vw, 5.7rem);
		line-height: 0.98;
		letter-spacing: 0;
		margin-bottom: var(--spacing-xl);
	}

	.lede {
		max-width: 720px;
		color: var(--color-muted);
		font-size: var(--font-size-xl);
		line-height: 1.55;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-md);
		margin-top: var(--spacing-xl);
	}

	.field-notes {
		display: none;
	}

	.button {
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		color: var(--color-text);
		padding: 0.75rem 1rem;
		text-decoration: none;
	}

	.button.primary {
		background: var(--color-text);
		color: var(--color-bg);
	}

	.section-head {
		align-items: end;
		border-bottom: 1px solid var(--color-border);
		display: flex;
		justify-content: space-between;
		gap: var(--spacing-lg);
		margin-bottom: var(--spacing-xl);
		padding-bottom: var(--spacing-md);
	}

	.section-head.compact {
		align-items: start;
	}

	.section-head h2 {
		font-size: var(--font-size-2xl);
	}

	.section-head a,
	.post-row,
	.card a {
		color: inherit;
		text-decoration: none;
	}

	.steps-grid,
	.service-grid {
		display: grid;
		gap: var(--spacing-lg);
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.steps-grid div {
		border-top: 2px solid var(--color-text);
		padding-top: var(--spacing-md);
	}

	.steps-grid span {
		color: var(--color-accent);
		display: block;
		font-size: var(--font-size-sm);
		font-weight: 900;
		margin-bottom: var(--spacing-sm);
	}

	.steps-grid strong {
		display: block;
		font-size: var(--font-size-lg);
		margin-bottom: var(--spacing-sm);
	}

	.steps-grid p,
	.service-item p,
	.card p,
	.post-row p,
	.text-band p,
	.home-cta p {
		color: var(--color-muted);
		line-height: 1.55;
	}

	.cards {
		display: grid;
		gap: var(--spacing-lg);
		grid-template-columns: repeat(4, minmax(0, 1fr));
	}

	.service-item,
	.card {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		padding: var(--spacing-lg);
	}

	.service-item h3 {
		font-size: var(--font-size-lg);
		margin-bottom: var(--spacing-sm);
	}

	.card img {
		aspect-ratio: 16 / 10;
		border-radius: calc(var(--radius) - 2px);
		height: auto;
		margin-bottom: var(--spacing-md);
		object-fit: cover;
		width: 100%;
	}

	.card span,
	.post-row span {
		color: var(--color-muted);
		font-size: var(--font-size-sm);
	}

	.card h3 {
		margin: var(--spacing-sm) 0;
	}

	.post-list {
		display: grid;
		gap: var(--spacing-md);
	}

	.post-row {
		border-bottom: 1px solid var(--color-border);
		display: grid;
		gap: var(--spacing-xs);
		padding: var(--spacing-lg) 0;
	}

	.text-band,
	.home-cta {
		max-width: var(--max-width);
	}

	.text-band h2,
	.home-cta h2 {
		font-size: var(--font-size-3xl);
		line-height: 1.08;
		margin-bottom: var(--spacing-md);
	}

	html[data-design="field"] .home-steps {
		border-bottom: 1px solid var(--color-border);
		padding-top: var(--spacing-3xl);
		padding-bottom: var(--spacing-3xl);
	}

	html[data-design="field"] .steps-grid div {
		border-color: var(--color-text);
	}

	@media (max-width: 860px) {
		.steps-grid,
		.service-grid,
		.cards {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 560px) {
		.steps-grid,
		.service-grid,
		.cards {
			grid-template-columns: 1fr;
		}

		.section-head {
			align-items: start;
			flex-direction: column;
		}
	}
</style>
