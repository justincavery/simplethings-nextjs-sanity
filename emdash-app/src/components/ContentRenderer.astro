---
import { PortableText } from "emdash/ui";
import CodeSnippet from "./CodeSnippet.astro";
import DemoEmbed from "./DemoEmbed.astro";
import SafeTable from "./SafeTable.astro";

export interface Props {
	value?: unknown;
}

const { value } = Astro.props;
const components = {
	type: {
		code: CodeSnippet,
		demo: DemoEmbed,
		table: SafeTable,
	},
};
---

{value ? <PortableText value={value as any} components={components} /> : null}
