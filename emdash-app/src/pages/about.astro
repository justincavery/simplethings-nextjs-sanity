---
import { getEmDashEntry } from "emdash";
import ContentRenderer from "../components/ContentRenderer.astro";
import Base from "../layouts/Base.astro";

const { entry: page, cacheHint } = await getEmDashEntry("pages", "about");
if (Astro.cache?.enabled) Astro.cache.set(cacheHint);
---

<Base title="About" description="About Simple Things Limited">
	<article class="page">
		<div class="content" {...page?.edit?.content}>
			{page?.data?.content ? <ContentRenderer value={page.data.content} /> : <p>Content coming soon.</p>}
		</div>
	</article>
</Base>

<style>
	.page {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: var(--spacing-4xl) var(--spacing-lg);
	}

	.content :global(h1) {
		font-size: var(--font-size-4xl);
		line-height: 1.05;
		margin-bottom: var(--spacing-xl);
	}

	.content :global(p) {
		color: var(--color-muted);
		font-size: var(--font-size-lg);
		line-height: 1.75;
		margin-bottom: var(--spacing-lg);
	}
</style>
