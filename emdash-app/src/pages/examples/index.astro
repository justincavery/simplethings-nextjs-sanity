---
import Base from "../../layouts/Base.astro";
import { examples } from "../../lib/examples";
---

<Base
	title="Examples"
	description="Runnable experiments, demos, and small technical showcases from Simple Things."
>
	<section class="examples-shell">
		<header class="examples-header">
			<p class="eyebrow">Examples</p>
			<h1>Runnable workbench notes.</h1>
			<p>
				Small deployed experiments that pair with articles, project notes, and technical
				ideas worth seeing directly in the browser.
			</p>
		</header>

		<div class="examples-list">
			{examples.map((example) => (
				<a href={`/examples/${example.slug}`} class="example-row">
					<div>
						<p class="example-meta">{example.tags.join(" / ")}</p>
						<h2>{example.title}</h2>
						<p>{example.summary}</p>
					</div>
					<span aria-hidden="true">View</span>
				</a>
			))}
		</div>
	</section>
</Base>

<style>
	.examples-shell {
		margin: 0 auto;
		max-width: var(--wide-width);
		padding: var(--spacing-4xl) var(--spacing-lg);
	}

	.examples-header {
		max-width: 760px;
	}

	.eyebrow,
	.example-meta {
		color: var(--color-accent);
		font-size: var(--font-size-sm);
		font-weight: 800;
		letter-spacing: 0;
		margin: 0 0 var(--spacing-sm);
		text-transform: uppercase;
	}

	h1 {
		font-size: var(--font-size-4xl);
		line-height: 1.02;
		margin: 0 0 var(--spacing-lg);
	}

	.examples-header p:not(.eyebrow),
	.example-row p {
		color: var(--color-muted);
		font-size: var(--font-size-lg);
		line-height: 1.7;
		margin: 0;
	}

	.examples-list {
		border-top: 2px solid var(--color-text);
		margin-top: var(--spacing-3xl);
	}

	.example-row {
		align-items: center;
		border-bottom: 1px solid var(--color-border);
		color: inherit;
		display: grid;
		gap: var(--spacing-lg);
		grid-template-columns: minmax(0, 1fr) auto;
		padding: var(--spacing-xl) 0;
		text-decoration: none;
	}

	.example-row:hover h2 {
		color: var(--color-accent);
	}

	.example-row h2 {
		font-size: var(--font-size-2xl);
		line-height: 1.15;
		margin: 0 0 var(--spacing-sm);
		transition: color 160ms ease;
	}

	.example-row span {
		border: 2px solid var(--color-text);
		font-size: var(--font-size-sm);
		font-weight: 800;
		padding: 0.55rem 0.75rem;
		text-transform: uppercase;
	}

	@media (max-width: 680px) {
		.example-row {
			align-items: start;
			grid-template-columns: 1fr;
		}

		.example-row span {
			justify-self: start;
		}
	}
</style>
