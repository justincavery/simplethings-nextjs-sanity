---
import Base from "../../layouts/Base.astro";
import { getExample } from "../../lib/examples";

const example = getExample(Astro.params.slug);
if (!example) return Astro.redirect("/404");
---

<Base title={example.title} description={example.summary}>
	<article class="example-detail">
		<header class="example-hero">
			<div>
				<a href="/examples" class="back">Examples</a>
				<p class="eyebrow">{example.tags.join(" / ")}</p>
				<h1>{example.title}</h1>
				<p class="summary">{example.summary}</p>
			</div>
			<div class="actions">
				<a href={example.demoUrl} class="action primary">Open full screen</a>
				{example.articleUrl && <a href={example.articleUrl} class="action">Read article</a>}
			</div>
		</header>

		<section class="demo-frame" aria-label={`${example.title} runnable demo`}>
			<iframe
				src={example.demoUrl}
				title={`${example.title} runnable demo`}
				loading="eager"
			></iframe>
		</section>

		<section class="notes">
			<h2>Deploying more examples</h2>
			<p>
				This page is backed by a small examples manifest in the Astro app. Add the runnable
				artifact under <code>public/demos</code>, add one manifest entry, review through
				Wrangler, then deploy the Worker. CMS posts can then link to this page instead of
				carrying demo code inside Portable Text.
			</p>
		</section>
	</article>
</Base>

<style>
	.example-detail {
		margin: 0 auto;
		max-width: var(--wide-width);
		padding: var(--spacing-3xl) var(--spacing-lg) var(--spacing-4xl);
	}

	.example-hero {
		align-items: end;
		border-bottom: 2px solid var(--color-text);
		display: grid;
		gap: var(--spacing-xl);
		grid-template-columns: minmax(0, 1fr) auto;
		padding-bottom: var(--spacing-2xl);
	}

	.back,
	.eyebrow {
		color: var(--color-accent);
		font-size: var(--font-size-sm);
		font-weight: 800;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	.back {
		display: inline-block;
		margin-bottom: var(--spacing-xl);
		text-decoration: none;
	}

	.eyebrow {
		margin: 0 0 var(--spacing-sm);
	}

	h1 {
		font-size: var(--font-size-4xl);
		line-height: 1.02;
		margin: 0;
		max-width: 840px;
	}

	.summary,
	.notes p {
		color: var(--color-muted);
		font-size: var(--font-size-lg);
		line-height: 1.7;
		max-width: 760px;
	}

	.summary {
		margin: var(--spacing-lg) 0 0;
	}

	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-sm);
		justify-content: flex-end;
	}

	.action {
		border: 2px solid var(--color-text);
		color: inherit;
		font-size: var(--font-size-sm);
		font-weight: 800;
		padding: 0.72rem 0.9rem;
		text-decoration: none;
		text-transform: uppercase;
	}

	.action.primary {
		background: var(--color-accent);
		border-color: var(--color-accent);
		color: #fff;
	}

	.demo-frame {
		background: #090b10;
		border: 2px solid var(--color-text);
		margin-top: var(--spacing-2xl);
		min-height: 640px;
		overflow: hidden;
	}

	iframe {
		border: 0;
		display: block;
		height: min(78vh, 780px);
		min-height: 640px;
		width: 100%;
	}

	.notes {
		border-top: 1px solid var(--color-border);
		margin-top: var(--spacing-2xl);
		padding-top: var(--spacing-xl);
	}

	.notes h2 {
		font-size: var(--font-size-xl);
		margin: 0 0 var(--spacing-md);
	}

	code {
		background: color-mix(in srgb, var(--color-accent) 10%, transparent);
		border: 1px solid color-mix(in srgb, var(--color-accent) 22%, transparent);
		border-radius: 0.28rem;
		font-family: ui-monospace, "SFMono-Regular", "SF Mono", Consolas, "Liberation Mono", monospace;
		font-size: 0.86em;
		padding: 0.08em 0.34em;
	}

	@media (max-width: 760px) {
		.example-hero {
			align-items: start;
			grid-template-columns: 1fr;
		}

		.actions {
			justify-content: flex-start;
		}

		.demo-frame,
		iframe {
			min-height: 620px;
		}
	}
</style>
