---
import { decodeSlug, getEmDashEntry } from "emdash";
import { Image } from "emdash/ui";
import {
	asSeoData,
	entrySeoCanonical,
	entrySeoDescription,
	entrySeoImage,
	entrySeoTitle,
	ogImageFor,
} from "../../lib/seo";
import { dateTimeAttribute, formatDisplayDate } from "../../lib/dates";
import ContentRenderer from "../../components/ContentRenderer.astro";
import Base from "../../layouts/Base.astro";

const slug = decodeSlug(Astro.params.slug);
if (!slug) return Astro.redirect("/404");

const { entry: post, cacheHint } = await getEmDashEntry("posts", slug);
if (!post) return Astro.redirect("/404");

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

const data = post.data as Record<string, any>;
const seo = asSeoData(data.seo);
const seoTitle = entrySeoTitle(seo, String(data.title || "Post"));
const seoDescription = entrySeoDescription(
	seo,
	data.excerpt,
	data.content,
	"A technical note from Simple Things.",
);
const generatedOgImage = ogImageFor(Astro.url, undefined, `/og/posts/${encodeURIComponent(post.id)}.png`);
const seoImage = entrySeoImage(seo, generatedOgImage);
const canonical = entrySeoCanonical(seo) || `/posts/${post.id}`;
---

<Base title={seoTitle} description={seoDescription} image={seoImage} canonical={canonical} type="article">
	<article class="post post-detail">
		<header>
			<a href="/blog" class="back">Blog</a>
			<p>
				<time datetime={dateTimeAttribute(data.date)}>{formatDisplayDate(data.date)}</time>
			</p>
			<h1 {...post.edit.title}>{data.title}</h1>
			{data.excerpt && <p class="excerpt" {...post.edit.excerpt}>{data.excerpt}</p>}
		</header>
		{data.featured_image && <div class="image" {...post.edit.featured_image}><Image image={data.featured_image} /></div>}
		<div class="content" {...post.edit.content}>
			<ContentRenderer value={data.content} />
		</div>
		<section class="post-cta">
			<p class="eyebrow">Need help with something similar?</p>
			<h2>Turn the rough edge into a simpler system.</h2>
			<p>
				I help teams with technical architecture, DevOps, CI/CD, performance,
				replatforming, and practical AI process improvement.
			</p>
			<a href="/contact">Start a conversation</a>
		</section>
	</article>
</Base>

<style>
	.post {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: var(--spacing-4xl) var(--spacing-lg);
	}

	.back,
	header p {
		color: var(--color-muted);
		font-size: var(--font-size-sm);
	}

	.back {
		text-decoration: none;
	}

	h1 {
		font-size: var(--font-size-4xl);
		line-height: 1.05;
		margin: var(--spacing-md) 0;
	}

	.excerpt {
		color: var(--color-muted);
		font-size: var(--font-size-lg);
		line-height: 1.65;
	}

	.image img {
		border-radius: var(--radius);
		height: auto;
		margin: var(--spacing-2xl) 0;
		width: 100%;
	}

	.content :global(p),
	.content :global(li) {
		font-size: var(--font-size-lg);
		line-height: 1.8;
		margin-bottom: var(--spacing-lg);
	}

	.content :global(:not(pre) > code) {
		background: color-mix(in srgb, var(--color-accent) 10%, transparent);
		border: 1px solid color-mix(in srgb, var(--color-accent) 22%, transparent);
		border-radius: 0.28rem;
		color: var(--color-text);
		font-family: ui-monospace, "SFMono-Regular", "SF Mono", Consolas, "Liberation Mono", monospace;
		font-size: 0.86em;
		padding: 0.08em 0.34em;
		white-space: normal;
	}

	.content :global(h2),
	.content :global(h3) {
		margin: var(--spacing-2xl) 0 var(--spacing-md);
	}

	.post-cta {
		border-top: 2px solid var(--color-text);
		margin-top: var(--spacing-3xl);
		padding-top: var(--spacing-xl);
	}

	.post-cta .eyebrow {
		color: var(--color-accent);
		font-size: var(--font-size-sm);
		font-weight: 800;
		margin-bottom: var(--spacing-md);
		text-transform: uppercase;
	}

	.post-cta h2 {
		font-size: var(--font-size-2xl);
		line-height: 1.15;
		margin-bottom: var(--spacing-sm);
	}

	.post-cta p:not(.eyebrow) {
		color: var(--color-muted);
		font-size: var(--font-size-lg);
		line-height: 1.65;
		margin-bottom: var(--spacing-lg);
	}

	.post-cta a {
		background: var(--color-text);
		color: var(--color-bg);
		display: inline-flex;
		font-weight: 800;
		padding: 0.85rem 1rem;
		text-decoration: none;
	}
</style>
