---
import { getEmDashCollection } from "emdash";
import { dateTimeAttribute, formatDisplayDate } from "../../lib/dates";
import Base from "../../layouts/Base.astro";

const { entries, cacheHint } = await getEmDashCollection("posts");
const posts = entries.sort((a, b) => String(b.data.date || "").localeCompare(String(a.data.date || "")));

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);
---

<Base
	title="Technical Notes and Consultancy Writing"
	description="Technical notes on architecture, DevOps, CI/CD, performance, replatforming, Cloudflare, CMS work, and practical AI process improvement."
	canonical="/blog"
>
	<section class="archive">
		<header>
			<h1>Blog</h1>
			<p>Technical notes, recovery paths, and occasional longer thoughts.</p>
		</header>
		<div class="posts">
			{posts.map((post) => (
				<a href={`/posts/${post.id}`} class="post">
					<time datetime={dateTimeAttribute(post.data.date)}>
						{formatDisplayDate(post.data.date)}
					</time>
					<h2>{post.data.title}</h2>
					<p>{post.data.excerpt}</p>
				</a>
			))}
		</div>
	</section>
</Base>

<style>
	.archive {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: var(--spacing-4xl) var(--spacing-lg);
	}

	header {
		margin-bottom: var(--spacing-2xl);
	}

	h1 {
		font-size: var(--font-size-4xl);
		line-height: 1.05;
		margin-bottom: var(--spacing-md);
	}

	header p,
	.post p {
		color: var(--color-muted);
		line-height: 1.65;
	}

	.post {
		border-top: 1px solid var(--color-border);
		color: inherit;
		display: block;
		padding: var(--spacing-xl) 0;
		text-decoration: none;
	}

	.post time {
		color: var(--color-muted);
		font-size: var(--font-size-sm);
	}

	.post h2 {
		font-size: var(--font-size-xl);
		margin: var(--spacing-xs) 0;
	}
</style>
