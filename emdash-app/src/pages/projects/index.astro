---
import { getEmDashCollection } from "emdash";
import type { MediaValue } from "emdash";
import { Image } from "emdash/ui";
import Base from "../../layouts/Base.astro";

const { entries: projects, cacheHint } = await getEmDashCollection("projects");
const asMedia = (value: unknown) =>
	value as MediaValue | string | null | undefined;
if (Astro.cache?.enabled) Astro.cache.set(cacheHint);
---

<Base
	title="Technical Architecture and Platform Case Studies"
	description="Case studies covering technical architecture, DevOps, CI/CD, observability, performance, Cloudflare platforms, APIs, and product engineering."
	canonical="/projects"
>
	<section class="archive">
		<header>
			<h1>Projects</h1>
			<p>Case studies from a technical point of view and a business-benefit point of view.</p>
		</header>
		<div class="cards">
			{projects.map((project) => (
				<article class="card">
					<a href={`/projects/${project.id}`}>
						{asMedia(project.data.featured_image) && <Image image={asMedia(project.data.featured_image)} />}
						<span>{project.data.year} {project.data.project_status ? `- ${project.data.project_status}` : ""}</span>
						<h2>{project.data.title}</h2>
						<p>{project.data.summary}</p>
					</a>
				</article>
			))}
		</div>
	</section>
</Base>

<style>
	.archive {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-4xl) var(--spacing-lg);
	}

	header {
		max-width: var(--max-width);
		margin-bottom: var(--spacing-2xl);
	}

	h1 {
		font-size: var(--font-size-4xl);
		line-height: 1.05;
		margin-bottom: var(--spacing-md);
	}

	header p,
	.card p {
		color: var(--color-muted);
		line-height: 1.65;
	}

	.cards {
		display: grid;
		gap: var(--spacing-xl);
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	.card {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		padding: var(--spacing-lg);
	}

	.card a {
		color: inherit;
		text-decoration: none;
	}

	.card img {
		aspect-ratio: 16 / 10;
		border-radius: calc(var(--radius) - 2px);
		height: auto;
		margin-bottom: var(--spacing-lg);
		object-fit: cover;
		width: 100%;
	}

	.card span {
		color: var(--color-muted);
		font-size: var(--font-size-sm);
	}

	.card h2 {
		font-size: var(--font-size-xl);
		margin: var(--spacing-xs) 0;
	}

	@media (max-width: 760px) {
		.cards {
			grid-template-columns: 1fr;
		}
	}
</style>
