---
import { decodeSlug, getEmDashEntry } from "emdash";
import { Image } from "emdash/ui";
import {
	asSeoData,
	entrySeoCanonical,
	entrySeoDescription,
	entrySeoImage,
	entrySeoTitle,
	ogImageFor,
} from "../../lib/seo";
import ContentRenderer from "../../components/ContentRenderer.astro";
import Base from "../../layouts/Base.astro";

const slug = decodeSlug(Astro.params.slug);
if (!slug) return Astro.redirect("/404");

const { entry: project, cacheHint } = await getEmDashEntry("projects", slug);
if (!project) return Astro.redirect("/404");

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

const data = project.data as Record<string, any>;
const seo = asSeoData(data.seo);
const seoTitle = entrySeoTitle(seo, String(data.title || "Project"));
const seoDescription = entrySeoDescription(
	seo,
	data.summary,
	data.content,
	"A Simple Things case study from a technical and business-benefit point of view.",
);
const generatedOgImage = ogImageFor(Astro.url, undefined, `/og/projects/${encodeURIComponent(project.id)}.png`);
const seoImage = entrySeoImage(seo, generatedOgImage);
const canonical = entrySeoCanonical(seo) || `/projects/${project.id}`;

type CapabilityGroup = {
	category: string;
	items: string[];
};

function isRecord(value: unknown): value is Record<string, unknown> {
	return typeof value === "object" && value !== null && !Array.isArray(value);
}

function textValue(value: unknown): string {
	return typeof value === "string" ? value.trim() : "";
}

function splitCapabilities(value: unknown): string[] {
	return textValue(value)
		.split(",")
		.map((item) => item.trim())
		.filter(Boolean);
}

function normaliseList(value: unknown, keys: string[]): string[] {
	if (!Array.isArray(value)) return [];

	return value
		.map((item) => {
			if (typeof item === "string") return item.trim();
			if (!isRecord(item)) return "";
			for (const key of keys) {
				const found = textValue(item[key]);
				if (found) return found;
			}
			return "";
		})
		.filter(Boolean);
}

function normaliseCapabilities(value: unknown): CapabilityGroup[] {
	if (!Array.isArray(value)) return [];

	const grouped = value
		.map((item) => {
			if (typeof item === "string") {
				return { category: "Capabilities", items: [item.trim()].filter(Boolean) };
			}
			if (!isRecord(item)) return null;

			const category = textValue(item.category) || "Capabilities";
			const items = splitCapabilities(item.capabilities);
			return items.length ? { category, items } : null;
		})
		.filter((item): item is CapabilityGroup => Boolean(item));

	if (!grouped.length) return [];

	const legacyItems = grouped.filter((item) => item.category === "Capabilities").flatMap((item) => item.items);
	const structuredItems = grouped.filter((item) => item.category !== "Capabilities");

	return legacyItems.length && !structuredItems.length
		? [{ category: "Capabilities", items: legacyItems }]
		: grouped;
}

const businessBenefits = normaliseList(data.business_benefits, ["benefit", "text", "title"]);
const technicalHighlights = normaliseList(data.technical_highlights, ["highlight", "text", "title"]);
const capabilityGroups = normaliseCapabilities(data.stack);
---

<Base title={seoTitle} description={seoDescription} image={seoImage} canonical={canonical}>
	<article class="project">
		<header class="project-head">
			<a href="/projects" class="back">Projects</a>
			<p class="project-meta">{data.year} {data.project_status ? `- ${data.project_status}` : ""}</p>
			<h1 {...project.edit.title}>{data.title}</h1>
			{data.summary && <p class="summary" {...project.edit.summary}>{data.summary}</p>}
			{data.url && (
				<div class="project-actions">
					<a href={data.url} class="external" target="_blank" rel="noopener noreferrer">View live project</a>
				</div>
			)}
		</header>
		{data.featured_image && <div class="image" {...project.edit.featured_image}><Image image={data.featured_image} /></div>}
		<div class="details">
			<section>
				<h2>Business benefits</h2>
				<ul>{businessBenefits.map((item) => <li>{item}</li>)}</ul>
			</section>
			<section>
				<h2>Technical highlights</h2>
				<ul>{technicalHighlights.map((item) => <li>{item}</li>)}</ul>
			</section>
			<section>
				<h2>Capabilities</h2>
				<div class="capability-groups">
					{capabilityGroups.map((group) => (
						<div class="capability-group">
							<h3>{group.category}</h3>
							<p>{group.items.join(", ")}</p>
						</div>
					))}
				</div>
			</section>
		</div>
		<div class="content" {...project.edit.content}>
			<ContentRenderer value={data.content} />
		</div>
	</article>
</Base>

<style>
	.project {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-4xl) var(--spacing-lg);
	}

	.project-head,
	.content {
		max-width: var(--max-width);
	}

	.back,
	.project-meta {
		color: var(--color-muted);
		font-size: var(--font-size-sm);
	}

	.back {
		text-decoration: none;
	}

	.project-head {
		margin-bottom: var(--spacing-2xl);
	}

	.project-meta {
		margin-top: var(--spacing-sm);
	}

	h1 {
		font-size: var(--font-size-4xl);
		line-height: 1.05;
		margin: var(--spacing-md) 0;
	}

	.summary {
		color: var(--color-muted);
		font-size: var(--font-size-lg);
		line-height: 1.65;
		max-width: 820px;
	}

	.project-actions {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-md);
		margin-top: var(--spacing-lg);
	}

	.external {
		color: var(--color-accent);
		display: inline-flex;
		font-weight: 700;
	}

	.image {
		margin-bottom: var(--spacing-2xl);
	}

	.image img {
		aspect-ratio: 16 / 8;
		border-radius: var(--radius);
		display: block;
		height: auto;
		margin: 0;
		object-fit: cover;
		width: 100%;
	}

	.details {
		display: grid;
		gap: var(--spacing-lg);
		grid-template-columns: repeat(3, minmax(0, 1fr));
		margin-bottom: var(--spacing-2xl);
	}

	.details section {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		padding: var(--spacing-lg);
	}

	.details h2 {
		font-size: var(--font-size-lg);
		margin-bottom: var(--spacing-md);
	}

	.details li {
		color: var(--color-muted);
		line-height: 1.55;
		margin-bottom: var(--spacing-sm);
	}

	.content :global(p) {
		color: var(--color-muted);
		line-height: 1.7;
		margin-bottom: var(--spacing-sm);
	}

	.details ul {
		margin-left: 1.1rem;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-sm);
	}

	.tags span {
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		padding: 0.3rem 0.5rem;
	}

	.capability-groups {
		display: grid;
		gap: var(--spacing-md);
	}

	.capability-group {
		border-top: 1px solid var(--color-border);
		padding-top: var(--spacing-md);
	}

	.capability-group:first-child {
		border-top: 0;
		padding-top: 0;
	}

	.capability-group h3 {
		color: var(--color-text);
		font-size: var(--font-size-sm);
		font-weight: 800;
		margin-bottom: var(--spacing-xs);
	}

	.capability-group p {
		color: var(--color-muted);
		line-height: 1.55;
	}

	.content {
		margin-top: var(--spacing-2xl);
	}

	.content :global(p) {
		font-size: var(--font-size-lg);
	}

	.content :global(h2) {
		font-size: var(--font-size-2xl);
		line-height: 1.15;
		margin: var(--spacing-2xl) 0 var(--spacing-md);
	}

	.content :global(h3) {
		font-size: var(--font-size-xl);
		line-height: 1.2;
		margin: var(--spacing-xl) 0 var(--spacing-sm);
	}

	@media (max-width: 860px) {
		.details {
			grid-template-columns: 1fr;
		}
	}
</style>
