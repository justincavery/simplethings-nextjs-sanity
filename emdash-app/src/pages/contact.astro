---
import Base from "../layouts/Base.astro";
import { env as workerEnv } from "cloudflare:workers";

const env = workerEnv as unknown as { PUBLIC_TURNSTILE_SITE_KEY?: string };
const turnstileSiteKey =
	env.PUBLIC_TURNSTILE_SITE_KEY || "1x00000000000000000000AA";
const sent = Astro.url.searchParams.get("sent") === "1";
const error = Astro.url.searchParams.get("error");
const formStartedAt = Date.now();

const errorMessages: Record<string, string> = {
	again: "Please try that again.",
	details: "Please check the details and try again.",
	unavailable: "The form is unavailable right now.",
	verify: "Verification failed. Please try again.",
	wait: "Please wait a few minutes before sending another message.",
};
---

<Base title="Contact" description="Get in touch with Simple Things">
	<section class="contact">
		<div class="intro">
			<p class="eyebrow">Contact</p>
			<h1>Tell me what you are trying to make simpler.</h1>
			<p>
				For Cloudflare migrations, CMS rebuilds, web platforms, blockchain data,
				infrastructure recovery, or a calm second pair of senior engineering eyes.
			</p>
		</div>

		<form method="post" action="/api/contact" class="contact-form">
			{sent && <p class="notice success" role="status">Thanks. I will get back to you shortly.</p>}
			{error && <p class="notice error" role="alert">{errorMessages[error] || errorMessages.details}</p>}

			<div class="field-grid">
				<label>
					<span>Name</span>
					<input name="name" autocomplete="name" required minlength="2" maxlength="120" />
				</label>
				<label>
					<span>Email</span>
					<input name="email" type="email" autocomplete="email" required />
				</label>
			</div>

			<label>
				<span>Company</span>
				<input name="company" autocomplete="organization" maxlength="160" />
			</label>

			<label>
				<span>What can I help with?</span>
				<textarea name="message" rows="8" required minlength="20" maxlength="5000"></textarea>
			</label>

			<label class="trap" aria-hidden="true">
				<span>Website</span>
				<input name="website" tabindex="-1" autocomplete="off" />
			</label>

			<input type="hidden" name="form_started_at" value={formStartedAt} />

			<div class="form-footer">
				<div
					class="cf-turnstile"
					data-sitekey={turnstileSiteKey}
					data-action="contact"
					data-theme="auto"
				></div>
				<button type="submit">Send message</button>
			</div>
		</form>
	</section>

	<script
		is:inline
		src="https://challenges.cloudflare.com/turnstile/v0/api.js"
		async
		defer
	></script>
</Base>

<style>
	.contact {
		display: grid;
		gap: var(--spacing-2xl);
		grid-template-columns: minmax(0, 0.9fr) minmax(320px, 1.1fr);
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-4xl) var(--spacing-lg);
	}

	.intro {
		max-width: 560px;
	}

	.eyebrow {
		color: var(--color-accent);
		font-size: var(--font-size-sm);
		font-weight: 700;
		text-transform: uppercase;
	}

	h1 {
		font-size: var(--font-size-4xl);
		line-height: 1.05;
		margin: var(--spacing-md) 0 var(--spacing-xl);
	}

	p {
		color: var(--color-muted);
		font-size: var(--font-size-lg);
		line-height: 1.7;
	}

	.contact-form {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		display: grid;
		gap: var(--spacing-lg);
		padding: var(--spacing-xl);
	}

	.field-grid {
		display: grid;
		gap: var(--spacing-md);
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	label {
		display: grid;
		gap: var(--spacing-xs);
	}

	label span {
		font-size: var(--font-size-sm);
		font-weight: 700;
	}

	input,
	textarea {
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		color: var(--color-text);
		font: inherit;
		padding: 0.85rem 0.9rem;
		width: 100%;
	}

	textarea {
		line-height: 1.55;
		resize: vertical;
	}

	input:focus,
	textarea:focus {
		border-color: var(--color-accent);
		outline: 2px solid transparent;
	}

	.form-footer {
		align-items: center;
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-md);
		justify-content: space-between;
	}

	button {
		background: var(--color-text);
		border: 0;
		border-radius: var(--radius);
		color: var(--color-bg);
		cursor: pointer;
		font: inherit;
		font-weight: 700;
		padding: 0.8rem 1rem;
	}

	.notice {
		border-radius: var(--radius);
		font-size: var(--font-size-base);
		padding: 0.85rem 1rem;
	}

	.success {
		background: color-mix(in srgb, var(--color-accent) 12%, transparent);
		color: var(--color-text);
	}

	.error {
		background: color-mix(in srgb, #ef4444 12%, transparent);
		color: var(--color-text);
	}

	.trap {
		height: 1px;
		left: -10000px;
		overflow: hidden;
		position: absolute;
		top: auto;
		width: 1px;
	}

	@media (max-width: 860px) {
		.contact,
		.field-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
